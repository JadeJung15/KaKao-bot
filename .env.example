BOT_DISPLAY_NAME=운영봇
BOT_NAMES=운영봇,봇
# Required to create the first room admin safely.
ADMIN_NAMES=
# Owner emails that can open /admin after login.
OWNER_ADMIN_EMAILS=jadejung15@gmail.com
# Optional emergency key for scripts or recovery. The admin UI does not ask for it.
ADMIN_CONSOLE_TOKEN=
BUYER_TOKEN_SECRET=
PUBLIC_SITE_URL=https://pixgom.com
BOT_STATE_ID=main
DB_PATH=data/room-ops-db.json
MONTHLY_PRICE_KRW=5500
ADDITIONAL_ROOM_PRICE_KRW=2200

# Optional for Vercel persistent storage.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
PGSSL=require

# Optional buyer auth. Enables Supabase email login and Kakao OAuth button.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_KAKAO_ENABLED=false
KAKAO_OIDC_ENABLED=true
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# Optional default room guard.
REGISTERED_ROOM_IDS=gu25P5vi
REGISTERED_ROOM_LINKS=https://open.kakao.com/o/gu25P5vi
