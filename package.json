{
  "name": "kakao-room-ops-bot",
  "version": "0.5.07",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "build": "npm run build:console",
    "build:console": "vite build --config vite.console.config.mjs",
    "dev:console": "vite --config vite.console.config.mjs",
    "check:deploy": "npm run build:console && node scripts/predeploy-check.js",
    "smoke:local": "node scripts/smoke-check.js",
    "smoke:prod": "node scripts/smoke-check.js https://pixgom.com",
    "android:bundle": "node scripts/android-release-bundle.js",
    "android:release-report": "node scripts/android-release-bundle.js --report-only",
    "test:local": "node scripts/test-local.js",
    "reset": "node scripts/reset-db.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  }
}
